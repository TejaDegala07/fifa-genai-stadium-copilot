// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  name               String
  role               String   // fan, volunteer, security, medical, operations, transport
  badgeId            String?
  section            String?
  language           String   @default("en")
  wheelchairAccess   Boolean  @default(false)
  hearingAssistance  Boolean  @default(false)
  visualAssistance   Boolean  @default(false)
  largeFontSize      Boolean  @default(false)
  highContrast       Boolean  @default(false)
  voiceMode          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  alertsAcknowledged Alert[]  @relation("UserAlerts")
}

model Alert {
  id             String   @id @default(uuid())
  type           String   // 'info' | 'warning' | 'critical' | 'success'
  message        String
  timestamp      DateTime @default(now())
  targetAudience String?  // 'all', 'fan', 'security', etc.
  targetZone     String?
  acknowledged   Boolean  @default(false)
  acknowledgedBy String?
  acknowledgedUser User?  @relation("UserAlerts", fields: [acknowledgedBy], references: [id])
}

model Incident {
  id             String   @id @default(uuid())
  type           String   // 'medical' | 'security' | 'crowd' | 'maintenance' | 'transport' | 'other'
  severity       String   // 'low' | 'medium' | 'high' | 'critical'
  status         String   // 'active' | 'assigned' | 'resolved'
  description    String
  reportedAt     DateTime @default(now())
  resolvedAt     DateTime?
  location       String   // JSON string of location data
  assignedTeam   String?
  timeline       String   // JSON string of timeline events
}

model Report {
  id              String   @id @default(uuid())
  incidentId      String
  generatedAt     DateTime @default(now())
  summary         String
  causeAnalysis   String
  responseActions String   // JSON array of strings
  recommendations String   // JSON array of strings
  lessonsLearned  String   // JSON array of strings
}

model CrowdZone {
  id              String   @id
  label           String
  section         String
  density         Float
  capacity        Int
  currentCount    Int
  status          String   // 'safe' | 'moderate' | 'high' | 'critical'
  trend           String   // 'increasing' | 'stable' | 'decreasing'
  lastUpdated     DateTime @default(now())
}
